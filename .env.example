# Sanity CMS — public reads (safe to expose to the client).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity — server-only token for authenticated reads / drafts / revalidation webhooks.
# Generate at sanity.io/manage → API → Tokens (Viewer permission is enough for read).
SANITY_AUTH_TOKEN=

# Site URL — used for absolute URLs in metadata, OG images, canonical tags, etc.
# No trailing slash. Update after DNS cutover to https://heliskycargo.com.
NEXT_PUBLIC_SITE_URL=https://heliskycargo-staging.vercel.app

# Cloudflare Turnstile — spam protection for the quote form.
# Generate at dash.cloudflare.com → Turnstile → Add site (Invisible widget).
# Site key is public (exposed to the browser); secret stays server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# Resend — transactional email API for /api/quote.
# Generate at resend.com → API Keys (Sending access).
RESEND_API_KEY=
# Verified sender. During dev use the sandbox `onboarding@resend.dev` (only
# delivers to the Resend account owner). After DNS verification on
# heliskycargo.com, switch to something like `Heli SkyCargo <quotes@heliskycargo.com>`.
RESEND_FROM_EMAIL=onboarding@resend.dev
# Fallback recipient when the CMS `quoteFormConfig.recipient_email` is empty.
OPS_INBOX_FALLBACK=

